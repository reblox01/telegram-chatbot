# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ── AI Provider (pick ONE) ──
# Priority: Groq > Gemini > OpenRouter
# Groq recommended: no daily cap, 30 req/min, fast

# Option A: Groq (recommended — free, no daily cap)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Option B: Google Gemini (free, no daily cap)
# Get key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Option C: OpenRouter (50 free req/day, need credits for more)
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Bot Identity (optional — defaults to "AI Bot")
BOT_NAME=AI Bot
BOT_CREATOR=the developer

# ── Memory: Local vs Hosted ──
# Option A: Local file (works for dev, NOT for Vercel production)
# Leave these blank — bot uses data/memory.json by default

# Option B: Supabase (recommended for production — persistent, free)
# 1. Create a free project at supabase.com
# 2. Go to Settings → API → copy your Project URL and anon key
# 3. Run the SQL setup (see README.md)
SUPABASE_URL=
SUPABASE_KEY=

# Environment
NODE_ENV=development
