# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (from openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Bot Identity (optional — defaults to "AI Bot")
BOT_NAME=AI Bot
BOT_CREATOR=the developer

# ── Memory: Local vs Hosted ──
# Option A: Local file (works for dev, NOT for Vercel production)
# Leave these blank — bot uses data/memory.json by default

# Option B: Supabase (recommended for production — persistent, free)
# 1. Create a free project at supabase.com
# 2. Go to Settings → API → copy your Project URL and anon key
# 3. Run the SQL setup (see README.md)
SUPABASE_URL=
SUPABASE_KEY=

# Environment
NODE_ENV=development
